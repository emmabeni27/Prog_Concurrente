class User(chatroom: actorRef) extends Actor{
    import User._
    
    def receive: Receive = out
    
    def out: Receive = {
        case join => 
            chatroom ! register(self)
            context.become(in)
    }
    
    def in: Receive = {
        case send(text) => chatroom ! broadcast(self, text) //🪲 NO OLVIDDAR SLEF
        case receive(text) => prinln(s"$text")
        case leave => context.become(out)
    }
}

class Chatroom(logger: ActorRef) extends Actor{
    import Chatroom._
    
    def receive: Receive = state(List.empty)
    
    def state(users: List[ActorRef]): Receive = {
        
        case register(user) => 
            user ! Receive("Registro exitoso")
            context.become(state(users :+ user))
        
        case broadcast(from, text) =>
            users.foreach(elem => if(elem != from{
                elem ! Receive(text)
            }))
            logger ! save(from, text)
        
        case remove(user) => 
            //context.become(state(users - user))
            context.become(state(users.filterNot(_ == user)))
    }
}
