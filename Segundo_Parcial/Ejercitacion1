class Queue<E> {
    class Node<E>(val item: E, var next: Node<E>? = null)

    private var head: Node<E>? = AtomicReference <Node<E>> (null)
    private var tail: Node<E>? = AtomicReference <Node<E>> (null)

    fun enqueue(item: E) {
    
        val newNode = Node(item, null)
        
        val t = tail.get()
        val next = t.next.get()
        
        while(true){
        //nunca tail == null porque está el dummy
            if (next == null){
                if(t.next.compareAndSet(null, newNode)){
                    tail.compareAndSet(t, newNode)
                    return
                }
            }
            else{
                tail.compareAndSet(t, next)
            }
        }
    }

    fun dequeue(): E? {
        
        while(true){
            val first = head.get()
            val last = tail.get()
            val second = first.next.get()
            
            if(next == null){
                return null
            }
            if(first == last){
                tail.compareAndSet(last, second)
                continue
            }
            if(head.compareAndSet(first, second)){
                return second.item
            }
        }
    }
}

