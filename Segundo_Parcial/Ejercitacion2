class Stack<E> {
    class Node<E>(val item: E, var next: Node<E>? = null)

    private var top: Node<E>? = AtomicReference<Node<E>> (null)

    fun push(item: E) {
        
        while(true){
            val oldTop = top.get()
            val updateNode = Node(item, oldTop)
            if(top.compareAndSet(oldTop, updateNode){
                return
            })
        }
    }

    fun pop(): E? {
    
        while(true){
            val oldTop = top.get()
            val newTop = oldTop.next.get()
        }
        
        if(top.compareAndSet(oldTop, newTop)){
            return oldTop.item
        }
    }
}
