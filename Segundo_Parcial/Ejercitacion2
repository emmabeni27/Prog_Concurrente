object triage{
    case class Assign(patient: String, name: ActorRef, severity: Int)
}

object doctor{
    case class Attend(patient: String, name: ActorRef, priority: String)
    case class Notify(name: ActorRef)
}

object patient{
    case object Arrive
    case class Done(name: ActorRef, priority: String)
}

class Triage(doctor: ActorRef) extends Actor{ //asumo médico único
    
    import Triage._
    
    def receive: Receive = {
        case Assign(patient, name, severity) => 
            val priority = if (severity>7) "HIGH" else "LOW"
            doctor ! Attend(patient, name, priority)
    }
}

class Doctor extends Actor {
  import Doctor._
  import context.dispatcher

  def receive: Receive = libre

  def libre: Receive = {
    case Attend(patient, name, priority) =>
      println(s"[Doctor] Attending $name with priority $priority")
      context.system.scheduler.scheduleOnce(2.seconds, self, FinishedAttending(patient, name, priority))
      context.become(ocupado(Queue.empty))
  }

  def ocupado(queue: Queue[(ActorRef, String, String)]): Receive = {
    case Attend(patient, name, priority) =>
      context.become(ocupado(queue :+ (patient, name, priority)))

    case FinishedAttending(patient, name, priority) =>
      patient ! Done(name, priority)
      queue.headOption match {
        case Some((p, n, pr)) =>
          self ! Attend(p, n, pr)
          context.become(libre)
        case None =>
          context.become(libre)
      }
  }
}

class Patient(triage: ActorRef, name: String) extends Actor{
    import Patient._
    
    def recieve: Recieve = destendido(8)
    
    def desatendido(priority: Int): Receive = {
        case Arrive => triage ! Assign(name, self, priority)
        context.become(enTriage)
    }
    
    def enTriage: Receive = {
        case Done(name, priority) => 
            println!(s"$name recicbió atención para su poribelma de prioridad $priority")
            context.become(atendido)
    }
    
}
